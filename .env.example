SERVER_ADDR=:8080
DEBUG_ADDR=:6060

MYSQL_DSN=root:password@tcp(localhost:3306)/go_chat?charset=utf8mb4&parseTime=True&loc=Local

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
MAX_CONCURRENT_LLM=2
USER_LLM_RATE_LIMIT=10
USER_LLM_RATE_WINDOW_SECONDS=60
IP_RATE_LIMIT=60
IP_RATE_WINDOW_SECONDS=60

# Benchmark mode only: temporarily raise rate limits before running scripts/benchmark_suite.py
# USER_LLM_RATE_LIMIT=1000
# IP_RATE_LIMIT=10000

OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=qwen2.5:3b

JWT_SECRET=replace-with-a-random-secret
JWT_EXPIRE_HOURS=24

# Optional MQ event publisher. Set MQ_ENABLED=true when RabbitMQ is available.
MQ_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=chat.events
RABBITMQ_ROUTING_KEY=chat.event
RABBITMQ_QUEUE=chat.events.log
RABBITMQ_BINDING_KEY=chat.*

# Optional async chat task queue. Set true when RabbitMQ is available and worker is running.
ASYNC_QUEUE_ENABLED=false
RABBITMQ_TASK_EXCHANGE=chat.tasks
RABBITMQ_TASK_ROUTING_KEY=chat.task.created
RABBITMQ_TASK_QUEUE=chat.tasks.worker
RABBITMQ_TASK_BINDING_KEY=chat.task.*
WORKER_CONCURRENCY=2
CHAT_JOB_MAX_RETRY=3

# Optional API key for Coze HTTP nodes/custom plugin calls.
# If empty, /api/coze/* endpoints are not protected by this middleware.
COZE_API_KEY=
COZE_DEFAULT_USER_ID=coze-default-user
